---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { authConfig, authorizedEditors } from '../../lib/auth';
import { siteConfig } from '../../lib/site';

const runtime = {
  storageKey: authConfig.storageKey,
  authorizedEditors,
  repo: siteConfig.githubRepo
};
---
<BaseLayout title="内容编辑 | RosenIcu" description="白名单账号使用的内容编辑入口。">
  <section class="hero auth-hero">
    <div>
      <p class="eyebrow">Editor</p>
      <h1>内容编辑入口。</h1>
      <p class="lede">白名单 GitHub 账号登录后，可以生成博客文章或进度记录的 Markdown 内容；如果 exchange 服务返回 token，也可以直接提交到仓库。</p>
    </div>
    <aside class="callout">
      <p class="eyebrow">Access</p>
      <h2 data-admin-title>检查登录状态</h2>
      <p class="lede" data-admin-detail>未授权时不会显示编辑表单。</p>
    </aside>
  </section>

  <section class="section">
    <div class="card" data-admin-locked>
      <h2>需要白名单账号</h2>
      <p data-admin-message>请先通过左上角账号菜单使用 GitHub 登录。</p>
    </div>

    <form class="card editor-form" data-editor-form hidden>
      <div>
        <h2>新建内容</h2>
        <p>先生成 Markdown 草稿；授权会话包含 token 时，可以直接写入 GitHub 仓库。</p>
      </div>
      <label>
        类型
        <select name="type">
          <option value="progress">进度记录</option>
          <option value="blog">博客文章</option>
        </select>
      </label>
      <label>
        标题
        <input name="title" required placeholder="例如：重构登录流程" />
      </label>
      <label>
        描述 / 项目
        <input name="description" placeholder="博客描述，或进度对应项目" />
      </label>
      <label>
        标签
        <input name="tags" placeholder="用英文逗号分隔，例如 astro, auth" />
      </label>
      <label>
        正文
        <textarea name="body" rows="10" placeholder="写下这次记录的内容。"></textarea>
      </label>
      <div class="project-links">
        <button class="button-link" type="submit">生成 Markdown</button>
        <button class="button-link secondary" type="button" data-publish-action>提交到 GitHub</button>
        <a class="button-link secondary" href={`https://github.com/${siteConfig.githubRepo}`}>打开仓库</a>
      </div>
      <p data-editor-status>尚未生成内容。</p>
      <label>
        生成结果
        <textarea name="output" rows="14" readonly></textarea>
      </label>
    </form>
  </section>

  <script is:inline define:vars={{ runtime }}>
    (() => {
      const locked = document.querySelector('[data-admin-locked]');
      const form = document.querySelector('[data-editor-form]');
      const title = document.querySelector('[data-admin-title]');
      const detail = document.querySelector('[data-admin-detail]');
      const message = document.querySelector('[data-admin-message]');
      const status = document.querySelector('[data-editor-status]');
      const publishAction = document.querySelector('[data-publish-action]');

      const getSession = () => {
        try {
          return JSON.parse(localStorage.getItem(runtime.storageKey) || 'null');
        } catch {
          return null;
        }
      };

      const isAuthorized = (session) => Boolean(session?.login && runtime.authorizedEditors.includes(session.login));

      const render = () => {
        const session = getSession();
        const authorized = isAuthorized(session);
        locked.hidden = authorized;
        form.hidden = !authorized;
        title.textContent = authorized ? '编辑权限已启用' : '需要登录';
        detail.textContent = authorized ? `当前账号：${session.login}` : '请通过账号菜单使用 GitHub 登录。';
        message.textContent = session ? '当前账号不在白名单内。' : '请先通过左上角账号菜单使用 GitHub 登录。';
        publishAction.disabled = !authorized || !session?.access_token;
        publishAction.textContent = session?.access_token ? '提交到 GitHub' : '缺少提交 token';
      };

      const slugify = (value) => value
        .trim()
        .toLowerCase()
        .replace(/[^a-z0-9\u4e00-\u9fa5]+/g, '-')
        .replace(/^-+|-+$/g, '') || 'untitled';

      const formatLocalDate = (date) => {
        const year = date.getFullYear();
        const month = String(date.getMonth() + 1).padStart(2, '0');
        const day = String(date.getDate()).padStart(2, '0');
        return `${year}-${month}-${day}`;
      };

      const buildMarkdown = () => {
        const data = new FormData(form);
        const type = String(data.get('type'));
        const titleValue = String(data.get('title') || '').trim();
        const description = String(data.get('description') || '').trim();
        const tags = String(data.get('tags') || '')
          .split(',')
          .map((tag) => tag.trim())
          .filter(Boolean);
        const body = String(data.get('body') || '').trim();
        const date = formatLocalDate(new Date());
        const slug = slugify(titleValue);
        const path = `src/content/${type}/${slug}.md`;
        const frontmatter = type === 'blog'
          ? [
              '---',
              `title: ${titleValue}`,
              `description: ${description || titleValue}`,
              `date: ${date}`,
              'tags:',
              ...(tags.length ? tags.map((tag) => `  - ${tag}`) : ['  - notes']),
              '---'
            ]
          : [
              '---',
              `title: ${titleValue}`,
              `date: ${date}`,
              'status: active',
              ...(description ? [`project: ${description}`] : []),
              'tags:',
              ...(tags.length ? tags.map((tag) => `  - ${tag}`) : ['  - progress']),
              '---'
            ];
        const content = [...frontmatter, '', body || '正文内容。', ''].join('\n');
        return { path, content, title: titleValue };
      };

      const updateOutput = () => {
        const output = form.elements.namedItem('output');
        const markdown = buildMarkdown();
        output.value = [`# 建议文件：${markdown.path}`, '', markdown.content].join('\n');
        status.textContent = `已生成 ${markdown.path}`;
        return markdown;
      };

      const contentUrl = (path) => `https://api.github.com/repos/${runtime.repo}/contents/${encodeURI(path)}`;

      const encodeBase64 = (value) => {
        const bytes = new TextEncoder().encode(value);
        let binary = '';
        for (const byte of bytes) {
          binary += String.fromCharCode(byte);
        }
        return btoa(binary);
      };

      const getExistingSha = async (path, token) => {
        const response = await fetch(contentUrl(path), {
          headers: {
            authorization: `Bearer ${token}`,
            accept: 'application/vnd.github+json'
          }
        });

        if (response.status === 404) {
          return null;
        }

        if (!response.ok) {
          throw new Error(String(response.status));
        }

        const file = await response.json();
        return typeof file.sha === 'string' ? file.sha : null;
      };

      form.addEventListener('submit', (event) => {
        event.preventDefault();
        updateOutput();
      });

      publishAction.addEventListener('click', async () => {
        const session = getSession();
        if (!isAuthorized(session)) {
          status.textContent = '当前账号没有编辑权限。';
          return;
        }

        if (!session.access_token) {
          status.textContent = '当前会话没有提交 token。请让 exchange 服务返回 access_token，或仅使用生成的 Markdown 手动提交。';
          return;
        }

        if (!form.reportValidity()) {
          return;
        }

        const markdown = updateOutput();
        status.textContent = '正在检查 GitHub 文件状态...';

        let sha = null;
        try {
          sha = await getExistingSha(markdown.path, session.access_token);
        } catch (error) {
          status.textContent = `读取文件状态失败：${error.message}`;
          return;
        }

        status.textContent = sha ? '正在更新 GitHub 内容...' : '正在新增 GitHub 内容...';

        const response = await fetch(contentUrl(markdown.path), {
          method: 'PUT',
          headers: {
            authorization: `Bearer ${session.access_token}`,
            accept: 'application/vnd.github+json',
            'content-type': 'application/json'
          },
          body: JSON.stringify({
            message: `${sha ? 'Update' : 'Add'} ${markdown.title}`,
            content: encodeBase64(markdown.content),
            ...(sha ? { sha } : {})
          })
        });

        if (!response.ok) {
          status.textContent = `提交失败：${response.status}`;
          return;
        }

        status.textContent = `${sha ? '已更新' : '已新增'} ${markdown.path}。GitHub Pages 会在推送后重新部署。`;
      });

      window.addEventListener('rosenicu-auth-change', render);
      window.addEventListener('storage', render);
      render();
    })();
  </script>
</BaseLayout>
