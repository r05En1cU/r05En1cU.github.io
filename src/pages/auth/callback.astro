---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { authConfig, authorizedEditors } from '../../lib/auth';
import { siteConfig } from '../../lib/site';

const runtime = {
  ...authConfig,
  authorizedEditors,
  ownerName: siteConfig.ownerName
};
---
<BaseLayout title="GitHub 登录回调 | RosenIcu" description="处理 GitHub OAuth 登录回调。">
  <section class="hero auth-hero">
    <div>
      <p class="eyebrow">Account</p>
      <h1>正在完成 GitHub 登录。</h1>
      <p class="lede" data-auth-message>正在校验 GitHub 返回结果。</p>
    </div>
    <aside class="callout">
      <p class="eyebrow">OAuth</p>
      <h2 data-auth-title>等待授权结果</h2>
      <p class="lede" data-auth-detail>如果页面停在这里，请检查 OAuth Client ID 和 exchange URL 配置。</p>
    </aside>
  </section>

  <section class="section">
    <div class="card">
      <h2>登录状态</h2>
      <p data-auth-status>准备处理 GitHub 回调。</p>
      <div class="project-links">
        <a class="button-link secondary" href="/">回到首页</a>
        <a class="button-link secondary" href="/admin/">进入内容编辑</a>
      </div>
    </div>
  </section>

  <script is:inline define:vars={{ runtime }}>
    (() => {
      const title = document.querySelector('[data-auth-title]');
      const message = document.querySelector('[data-auth-message]');
      const detail = document.querySelector('[data-auth-detail]');
      const status = document.querySelector('[data-auth-status]');

      const setText = (target, value) => {
        if (target) target.textContent = value;
      };

      const fail = (reason, help) => {
        setText(title, '登录未完成');
        setText(message, reason);
        setText(detail, help);
        setText(status, `${reason} ${help}`);
      };

      const saveSession = (session) => {
        localStorage.setItem(runtime.storageKey, JSON.stringify(session));
        window.dispatchEvent(new CustomEvent('rosenicu-auth-change', { detail: session }));
      };

      const params = new URLSearchParams(window.location.search);
      const error = params.get('error');
      const code = params.get('code');
      const state = params.get('state');
      const expectedState = sessionStorage.getItem(runtime.stateKey);

      if (error) {
        fail('GitHub 拒绝了本次授权。', params.get('error_description') || '可以重新从账号菜单发起登录。');
        return;
      }

      if (!code || !state) {
        fail('缺少 GitHub OAuth 回调参数。', '请从账号菜单重新发起 GitHub 登录。');
        return;
      }

      if (!expectedState || state !== expectedState) {
        fail('OAuth state 校验失败。', '这次登录已被拒绝，请重新发起授权。');
        return;
      }

      sessionStorage.removeItem(runtime.stateKey);

      if (!runtime.exchangeUrl) {
        fail('还没有配置 OAuth exchange 服务。', '静态页面不能安全保存 GitHub client_secret。请配置 PUBLIC_GITHUB_OAUTH_EXCHANGE_URL，由后端或 Worker 使用 code 换取 token 并返回 GitHub 用户资料。');
        return;
      }

      const normalizeSession = (payload) => {
        const user = payload.user || payload;
        const login = user.login;
        const authorized = runtime.authorizedEditors.includes(login);
        return {
          login,
          name: user.name,
          avatar_url: user.avatar_url,
          html_url: user.html_url,
          access_token: payload.access_token || payload.token,
          authorized,
          issued_at: new Date().toISOString()
        };
      };

      const finish = async () => {
        setText(title, '正在校验账号');
        setText(message, 'GitHub 已返回授权码，正在通过 exchange 服务换取账号资料。');

        const response = await fetch(runtime.exchangeUrl, {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({
            code,
            state,
            redirect_uri: new URL(runtime.redirectPath, window.location.origin).toString()
          })
        });

        if (!response.ok) {
          throw new Error(`exchange failed: ${response.status}`);
        }

        const session = normalizeSession(await response.json());

        if (!session.login) {
          throw new Error('exchange service did not return a GitHub login');
        }

        saveSession(session);
        setText(title, session.authorized ? '白名单账号已登录' : 'GitHub 账号已登录');
        setText(message, session.authorized ? '你可以进入内容编辑页。' : '当前账号不在白名单内，暂时只能浏览。');
        setText(detail, `登录账号：${session.login}`);
        setText(status, session.authorized ? '授权通过，可以修改内容。' : '账号不在白名单内，内容编辑入口不会开放。');
        window.history.replaceState({}, document.title, window.location.pathname);
      };

      finish().catch((authError) => {
        fail('登录交换失败。', authError instanceof Error ? authError.message : '请检查 exchange 服务。');
      });
    })();
  </script>
</BaseLayout>
