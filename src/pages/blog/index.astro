---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat('zh-CN', { year: 'numeric', month: '2-digit', day: '2-digit' }).format(date);
---
<BaseLayout title="博客 | RosenIcu">
  <section class="hero">
    <div>
      <p class="eyebrow">Blog</p>
      <h1>文章和阶段性总结。</h1>
      <p class="lede">这里放更完整的技术笔记、复盘和想法。进度记录会先在日志里生长，成熟后再整理到这里。</p>
    </div>
  </section>

  <section class="section">
    <div class="article-list">
      {posts.map((post) => (
        <a class="article-link" href={`/blog/${post.id}/`}>
          <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
          <span>
            <h3>{post.data.title}</h3>
            <p>{post.data.description}</p>
            <span class="tag-list">
              {post.data.tags.map((tag) => <span class="tag">{tag}</span>)}
            </span>
          </span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
