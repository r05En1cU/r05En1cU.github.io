---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const entries = (await getCollection('progress'))
  .filter((entry) => !entry.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat('zh-CN', { year: 'numeric', month: '2-digit', day: '2-digit' }).format(date);
---
<BaseLayout title="进度记录 | RosenIcu">
  <section class="hero">
    <div>
      <p class="eyebrow">Progress</p>
      <h1>短记录、阶段推进和正在发生的事。</h1>
      <p class="lede">这里更像公开的工作日志，不要求每一条都完整，但要求能让未来的自己看懂当时在推进什么。</p>
    </div>
  </section>

  <section class="section">
    <div class="article-list">
      {entries.map((entry) => (
        <a class="article-link" href={`/progress/${entry.id}/`}>
          <time datetime={entry.data.date.toISOString()}>{formatDate(entry.data.date)}</time>
          <span>
            <span class={`status ${entry.data.status}`}>{entry.data.status}</span>
            <h3>{entry.data.title}</h3>
            {entry.data.project && <p>{entry.data.project}</p>}
            <span class="tag-list">
              {entry.data.tags.map((tag) => <span class="tag">{tag}</span>)}
            </span>
          </span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
